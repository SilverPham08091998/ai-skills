{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "SCRIPT=\"${CLAUDE_PLUGIN_ROOT}/scripts/check-todo-approval.sh\"; if [ ! -f \"$SCRIPT\" ]; then SCRIPT=\"$HOME/.claude/scripts/check-todo-approval.sh\"; fi; bash \"$SCRIPT\"",
            "statusMessage": "Checking TODO approval..."
          },
          {
            "type": "command",
            "command": "cat /dev/stdin | \"${CLAUDE_PLUGIN_ROOT}/scripts/mark-modified.sh\"",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/auto-test-build.sh\"",
            "timeout": 300,
            "statusMessage": "Running tests & build..."
          }
        ]
      }
    ]
  }
}
